# Supabase (Zürich region) — all personal data flows directly browser ↔ Zürich.
# Never set SUPABASE_SERVICE_ROLE_KEY in Vercel — it belongs only in Edge Function secrets.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<anon-publishable-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key-ONLY-for-local-edge-function-dev>

# Google Maps — referrer-restricted key, used for Geocoding + Directions + JS Maps.
# Public key (exposed in browser) — do not use for billing-sensitive APIs.
GOOGLE_MAPS_API_KEY=<restricted-key>

# Public site URL — used for OAuth redirects and absolute URLs in emails.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sprint-5 features (Mobile-PWA scan, batch-register, QR-labels)
# default OFF for client demos until Sprint 5 (~end of June 2026)
NEXT_PUBLIC_SHOW_SPRINT5_FEATURES=false
